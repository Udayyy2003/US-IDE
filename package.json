{
  "name": "us-ide",
  "version": "1.1.0",
  "description": "AI-Powered Desktop IDE",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\" \"npm run dev:auth\" \"npm run dev:python\"",
    "dev:react": "npm --prefix frontend run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:auth": "node server.js",
    "dev:python": "cd backend && python app.py",
    "build": "npm --prefix frontend run build",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.uday.uside",
    "productName": "US-IDE",
    "artifactName": "US-IDE-Setup.exe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      {
        "from": "frontend/dist",
        "to": "."
      },
      "backend/**/*",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "US-IDE",
      "license": "LICENSE.txt"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  }
}
