{
  "name": "us-ide",
  "version": "1.0.0",
  "description": "AI-Powered Desktop IDE",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "npm --prefix frontend run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm --prefix frontend run build",
    "electron": "electron .",
    "electron:build": "electron-builder --win"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "build": {
    "appId": "com.uday.uside",
    "productName": "US-IDE",
    "artifactName": "US-IDE-Setup.exe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "US-IDE",
      "license": "LICENSE.txt"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
